.area-picker {
  position: relative;
}

.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 4px 0;
}

.picker-text {
  font-size: 14px;
  color: #333;
  margin-right: 4px;
}

.picker-text.placeholder {
  color: #ccc;
}

.picker-arrow {
  width: 12px;
  height: 12px;
}

/* 弹窗遮罩 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
}

/* 弹窗 */
.picker-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 12px 12px 0 0;
  z-index: 1000;
  max-height: 60vh;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.popup-cancel {
  font-size: 14px;
  color: #999;
  padding: 4px 8px;
}

.popup-cancel:active {
  opacity: 0.7;
}

.popup-title {
  font-size: 16px;
  font-weight: 500;
  color: #333;
}

.popup-confirm {
  font-size: 14px;
  color: #07c160;
  padding: 4px 8px;
  font-weight: 500;
}

.popup-confirm:active {
  opacity: 0.7;
}

.popup-list {
  max-height: 50vh;
}

.popup-empty {
  padding: 36px 16px;
  text-align: center;
  color: #999;
  font-size: 14px;
}

.popup-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #f5f5f5;
}

.popup-item:active {
  background-color: #fafafa;
}

.popup-item.selected {
  background-color: #f0fff5;
}

.item-label {
  font-size: 14px;
  color: #333;
}

.item-check {
  font-size: 16px;
  color: #07c160;
  font-weight: 600;
}

.area-group {
  padding: 12px 16px 4px;
  border-bottom: 1px solid #f5f5f5;
}

.area-group-title {
  font-size: 13px;
  color: #666;
  font-weight: 500;
  margin-bottom: 10px;
}

.city-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.city-item {
  padding: 6px 10px;
  border: 1px solid #e5e5e5;
  border-radius: 4px;
  color: #333;
  font-size: 13px;
  background: #fafafa;
  margin-bottom: 8px;
}

.city-item.selected {
  color: #07c160;
  border-color: #07c160;
  background: #f0fff5;
}
