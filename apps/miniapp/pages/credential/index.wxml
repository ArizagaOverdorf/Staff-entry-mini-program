<view class="credential-container">
  <!-- 学历/学生证快捷入口 -->
  <view class="education-section" wx:if="{{loaded}}">
    <view class="education-header">
      <text class="education-title">学历/学生证</text>
      <text class="education-desc" wx:if="{{educationCredentials.length > 0}}">已上传 {{educationCredentials.length}} 项</text>
      <text class="education-desc" wx:else>选填，可上传学历或学生证</text>
    </view>
    <view class="education-actions">
      <button class="btn-education" data-type="education" bindtap="goToEducationUpload">上传学历/毕业证</button>
      <button class="btn-education btn-student-card" data-type="student_card" bindtap="goToEducationUpload">上传学生证</button>
    </view>
    <view class="education-list" wx:if="{{educationCredentials.length > 0}}">
      <view
        class="credential-card education-card"
        wx:for="{{educationCredentials}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goToEdit"
      >
        <view class="credential-card-top">
          <view class="credential-info">
            <text class="credential-name">{{item.name || '证件'}}</text>
            <text class="credential-type">{{item.typeName || ''}}</text>
          </view>
          <view class="tag {{getStatusClass(item.status)}}">{{getStatusLabel(item.status)}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 证件列表 -->
  <view class="credential-list" wx:if="{{credentials.length > 0}}">
    <view
      class="credential-card"
      wx:for="{{credentials}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToEdit"
    >
      <view class="credential-card-top">
        <view class="credential-info">
          <text class="credential-name">{{item.name || '证件'}}</text>
          <text class="credential-type">{{item.typeName || ''}}</text>
        </view>
        <view class="tag {{getStatusClass(item.status)}}">{{getStatusLabel(item.status)}}</view>
      </view>
      <view class="credential-card-bottom">
        <text class="credential-date" wx:if="{{item.expireDate}}">
          有效期至：{{item.expireDate}}
          <text wx:if="{{item.expiringSoon}}" class="expiring-badge">即将过期</text>
        </text>
        <text class="credential-date" wx:else>无有效期</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{loaded && credentials.length === 0}}">
    <image src="/images/empty.png" mode="aspectFit"></image>
    <text>暂无证件，请点击下方按钮上传</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>

  <!-- 上传按钮 -->
  <view class="credential-footer">
    <button class="btn-primary" bindtap="goToUpload">上传新证件</button>
  </view>
</view>
