<view class="credential-container">
  <!-- 证件列表 -->
  <view class="credential-list" wx:if="{{credentials.length > 0}}">
    <view
      class="credential-card"
      wx:for="{{credentials}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToEdit"
    >
      <view class="credential-card-top">
        <view class="credential-info">
          <text class="credential-name">{{item.name || '证件'}}</text>
          <text class="credential-type">{{item.typeName || ''}}</text>
        </view>
        <view class="tag {{getStatusClass(item.status)}}">{{getStatusLabel(item.status)}}</view>
      </view>
      <view class="credential-card-bottom">
        <text class="credential-date" wx:if="{{item.expireDate}}">
          有效期至：{{item.expireDate}}
          <text wx:if="{{item.expiringSoon}}" class="expiring-badge">即将过期</text>
        </text>
        <text class="credential-date" wx:else>无有效期</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{loaded && credentials.length === 0}}">
    <image src="/images/empty.png" mode="aspectFit"></image>
    <text>暂无证件，请点击下方按钮上传</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>

  <!-- 上传按钮 -->
  <view class="credential-footer">
    <button class="btn-primary" bindtap="goToUpload">上传新证件</button>
  </view>
</view>
