<view class="credential-container">
  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{loaded}}">
    <!-- 强准入资料 -->
    <view class="credential-section">
      <view class="section-header">
        <text class="section-title">强准入资料</text>
        <text class="section-desc">以下资料为入驻审核必填</text>
      </view>
      <view
        class="requirement-card"
        wx:for="{{requiredCredentialCards}}"
        wx:key="typeId"
        data-type="{{item.typeId}}"
        data-name="{{item.typeName}}"
        data-id="{{item.credentialId}}"
        bindtap="goToCredentialType"
      >
        <view class="requirement-main">
          <text class="requirement-title">{{item.title}}</text>
          <text class="requirement-desc">{{item.desc}}</text>
          <text class="requirement-files" wx:if="{{item.fileCount > 0}}">已上传 {{item.fileCount}} 张图片</text>
        </view>
        <view class="requirement-side">
          <text class="tag {{item.statusClass}}">{{item.statusLabel}}</text>
          <text class="requirement-action">{{item.actionText}}</text>
        </view>
      </view>
    </view>

    <!-- 技能证书 -->
    <view class="credential-section">
      <view class="section-header">
        <text class="section-title">技能证书</text>
        <text class="section-desc">可按实际技能上传多本证书</text>
      </view>
      <view class="requirement-card skill-upload-card" bindtap="goToSkillCertUpload">
        <view class="requirement-main">
          <text class="requirement-title">新增一本技能证书</text>
          <text class="requirement-desc">一人可上传多本证书，每本填写名称、等级并关联对应技能</text>
        </view>
        <view class="requirement-side">
          <text class="tag tag-info">可多本</text>
          <text class="requirement-action">去上传</text>
        </view>
      </view>
      <view wx:if="{{skillCertificates.length > 0}}">
        <view
          class="credential-card"
          wx:for="{{skillCertificates}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goToEdit"
        >
          <view class="credential-card-top">
            <view class="credential-info">
              <text class="credential-name">{{item.name || '技能证书'}}</text>
              <text class="credential-type">{{item.skillLevelText}}</text>
              <text class="credential-type" wx:if="{{item.linkedSkillText}}">{{item.linkedSkillText}}</text>
            </view>
            <view class="tag {{item.statusClass}}">{{item.statusLabel}}</view>
          </view>
        </view>
      </view>
      <view class="section-empty" wx:else>暂无技能证书。选择服务技能后，请上传对应证书并填写名称、等级。</view>
    </view>

    <!-- 选填资料 -->
    <view class="credential-section">
      <view class="section-header">
        <text class="section-title">选填资料</text>
        <text class="section-desc">学历/学生证、保险等按实际情况补充，有助于审核判断</text>
      </view>
      <view
        class="requirement-card optional-card"
        wx:for="{{optionalCredentialCards}}"
        wx:key="typeId"
        data-type="{{item.typeId}}"
        data-name="{{item.typeName}}"
        data-id="{{item.credentialId}}"
        bindtap="goToCredentialType"
      >
        <view class="requirement-main">
          <text class="requirement-title">{{item.title}}</text>
          <text class="requirement-desc">{{item.desc}}</text>
          <text class="requirement-files" wx:if="{{item.fileCount > 0}}">已上传 {{item.fileCount}} 张图片</text>
        </view>
        <view class="requirement-side">
          <text class="tag {{item.statusClass}}">{{item.statusLabel}}</text>
          <text class="requirement-action">{{item.actionText}}</text>
        </view>
      </view>
    </view>

    <!-- 已上传资料 -->
    <view class="credential-section" wx:if="{{credentials.length > 0}}">
      <view class="section-header">
        <text class="section-title">已上传资料</text>
        <text class="section-desc">点击可查看或更新</text>
      </view>
      <view
        class="credential-card"
        wx:for="{{credentials}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goToEdit"
      >
        <view class="credential-card-top">
          <view class="credential-info">
            <text class="credential-name">{{item.name || '证件'}}</text>
            <text class="credential-type">{{item.typeName || ''}}</text>
          </view>
          <view class="tag {{item.statusClass}}">{{item.statusLabel}}</view>
        </view>
        <view class="credential-card-bottom">
          <text class="credential-date" wx:if="{{item.expireDate}}">
            有效期至：{{item.expireDate}}
          </text>
          <text class="credential-date" wx:else>无有效期</text>
        </view>
      </view>
    </view>
  </block>

  <view class="credential-footer">
    <button class="btn-primary" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="handleSubmitReview">提交审核</button>
  </view>
</view>
