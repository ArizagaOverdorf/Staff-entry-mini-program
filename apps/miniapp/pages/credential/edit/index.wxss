.credential-edit-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  flex: 1;
}

.upload-section {
  background: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.upload-label {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 10px;
}

.upload-area {
  width: 100%;
  min-height: 160px;
  border: 1px dashed #ddd;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-area:active {
  background-color: #fafafa;
}

.upload-preview {
  width: 100%;
  max-height: 200px;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30px 0;
}

.upload-icon {
  font-size: 36px;
  color: #ccc;
  margin-bottom: 8px;
}

.upload-text {
  font-size: 13px;
  color: #999;
}

.status-display {
  display: flex;
  align-items: center;
  padding: 10px 0;
}

.status-label {
  font-size: 14px;
  color: #666;
  margin-right: 8px;
}

.status-value {
  font-size: 14px;
  font-weight: 500;
}

.status-value.success {
  color: #07c160;
}

.status-value.error {
  color: #f56c6c;
}

.status-value.warning {
  color: #faad14;
}

.card {
  background: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.card-title {
  font-size: 14px;
  color: #333;
  margin-bottom: 10px;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.skill-tag {
  padding: 6px 14px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 13px;
  color: #666;
  background: #fafafa;
}

.skill-tag-active {
  border-color: #07c160;
  color: #07c160;
  background: #f0fff4;
}

.selected-skills {
  margin-top: 10px;
  font-size: 12px;
  color: #07c160;
}

.selected-label {
  color: #666;
}

.no-skill-hint {
  margin-top: 8px;
  font-size: 12px;
  color: #f56c6c;
}

.form-submit-bar {
  padding: 10px 0 20px;
  background-color: #fff;
  border-top: 1px solid #f0f0f0;
}
