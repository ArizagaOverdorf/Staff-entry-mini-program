<view class="credential-edit-container">
  <scroll-view class="form-scroll" scroll-y>
    <view class="form-group">
      <view class="form-item">
        <text class="form-label">证件类型</text>
        <text wx:if="{{isTypeLocked}}" class="form-value fixed-type-value">{{typeName}}</text>
        <picker wx:else mode="selector" range="{{credTypes}}" range-key="label" bindchange="onTypeChange">
          <view class="form-value form-picker">{{typeName || '请选择证件类型'}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">{{nameLabel}}</text>
        <input
          class="form-input"
          value="{{name}}"
          placeholder="{{namePlaceholder}}"
          bindinput="onNameInput"
        />
      </view>

      <view wx:if="{{showNormalCredentialFields}}" class="form-item">
        <text class="form-label">证件编号</text>
        <input
          class="form-input"
          value="{{credentialNumber}}"
          placeholder="请输入证件编号"
          bindinput="onNumberInput"
        />
      </view>

      <view wx:if="{{showNormalCredentialFields}}" class="form-item">
        <text class="form-label">{{issuingAuthorityLabel}}</text>
        <input
          class="form-input"
          value="{{issuingAuthority}}"
          placeholder="{{issuingAuthorityPlaceholder}}"
          bindinput="onIssuingAuthorityInput"
        />
      </view>

      <view wx:if="{{requireExpiry}}" class="form-item">
        <text class="form-label">生效日期<text class="required-mark"> *</text></text>
        <picker mode="date" value="{{issueDate}}" start="2000-01-01" end="{{todayDate}}" bindchange="onIssueDateChange">
          <view class="form-value form-picker {{issueDate ? '' : 'form-placeholder'}}">
            {{issueDate || '请选择生效日期'}}
          </view>
        </picker>
      </view>
      <view wx:if="{{requireExpiry}}" class="form-item">
        <text class="form-label">有效期至<text class="required-mark"> *</text></text>
        <picker mode="date" value="{{expireDate}}" start="{{issueDate || '2000-01-01'}}" end="2099-12-31" bindchange="onExpireDateChange">
          <view class="form-value form-picker {{expireDate ? '' : 'form-placeholder'}}">
            {{expireDate || '请选择有效期至'}}
          </view>
        </picker>
      </view>

      <view wx:if="{{isSkillCert}}" class="form-item">
        <text class="form-label">等级</text>
        <picker mode="selector" range="{{skillLevelOptions}}" range-key="label" value="{{skillLevelIndex}}" bindchange="onSkillLevelChange">
          <view class="form-value form-picker {{skillLevel ? '' : 'form-placeholder'}}">
            {{skillLevel || '请选择等级'}}
          </view>
        </picker>
      </view>
    </view>

    <view wx:if="{{isSkillCert}}" class="card skill-section">
      <view class="skill-section-title">关联服务技能<text class="required-mark"> *</text></view>
      <view class="skill-section-desc">一本技能证书可以关联多个实际服务技能，至少选择一项。</view>
      <view class="skill-tags">
        <view
          wx:for="{{staffSkills}}"
          wx:key="categoryId"
          class="skill-tag {{item.checked ? 'skill-tag-active' : ''}}"
          data-id="{{item.categoryId}}"
          bindtap="onSkillToggle"
        >
          {{item.categoryName}}
        </view>
      </view>
      <view wx:if="{{selectedSkillNames.length}}" class="selected-skills">
        <text class="selected-label">已选：</text>{{selectedSkillText}}
      </view>
    </view>

    <!-- ID Card dual upload -->
    <view wx:if="{{isIdCard}}" class="upload-section">
      <text class="upload-label">居民身份证 - 人像面 <text class="required-mark">*</text></text>
      <view class="upload-area" bindtap="handleUploadIdCardFront">
        <image wx:if="{{idCardFrontUrl}}" class="upload-preview" src="{{idCardFrontUrl}}" mode="aspectFit" />
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">点击上传人像面</text>
        </view>
      </view>
    </view>

    <view wx:if="{{isIdCard}}" class="upload-section">
      <text class="upload-label">居民身份证 - 国徽面 <text class="required-mark">*</text></text>
      <view class="upload-area" bindtap="handleUploadIdCardBack">
        <image wx:if="{{idCardBackUrl}}" class="upload-preview" src="{{idCardBackUrl}}" mode="aspectFit" />
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">点击上传国徽面</text>
        </view>
      </view>
    </view>

    <!-- ID Card: ID number field -->
    <view wx:if="{{isIdCard}}" class="form-item id-card-number-item">
      <text class="form-label">身份证号<text class="required-mark"> *</text></text>
      <input
        class="form-input"
        type="idcard"
        value="{{credentialNumber}}"
        placeholder="请输入身份证号"
        bindinput="onNumberInput"
        bindconfirm="onIdCardConfirm"
        bindfocus="onIdCardFocus"
        bindblur="onIdCardBlur"
        maxlength="18"
        confirm-type="done"
        cursor-spacing="180"
      />
    </view>

    <!-- Keyboard spacer for ID card input -->
    <view wx:if="{{idCardKeyboardActive}}" class="keyboard-spacer"></view>

    <!-- Non-ID Card single upload -->
    <view wx:if="{{!isIdCard}}" class="upload-section">
      <text class="upload-label">{{isSkillCert ? '证书图片' : '证件图片'}}<text wx:if="{{isSkillCert}}" class="required-mark"> *</text></text>
      <view class="upload-area" bindtap="handleUploadImage">
        <image wx:if="{{fileUrl}}" class="upload-preview" src="{{fileUrl}}" mode="aspectFit" />
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">{{isSkillCert ? '点击上传证书图片' : '点击上传证件图片'}}</text>
        </view>
      </view>
    </view>

    <view class="form-group">
      <view class="form-item">
        <text class="form-label">备注</text>
        <input
          class="form-input"
          value="{{remark}}"
          placeholder="可选备注信息"
          bindinput="onRemarkInput"
        />
      </view>
    </view>
  </scroll-view>

  <view class="form-submit-bar">
    <button class="btn-primary {{isSubmitting ? 'btn-disabled' : ''}}" bindtap="handleSave" disabled="{{isSubmitting}}">
      {{isSubmitting ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
