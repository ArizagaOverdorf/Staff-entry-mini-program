<view class="credential-edit-container">
  <scroll-view class="form-scroll" scroll-y>
    <view class="form-group">
      <view class="form-item">
        <text class="form-label">证件类型</text>
        <picker range="{{credTypes}}" range-key="label" bindchange="onTypeChange">
          <view class="form-value">{{typeName || '请选择证件类型'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">证件名称</text>
        <input class="form-input" type="text" placeholder="请输入证件名称" value="{{name}}" bindinput="onNameInput" />
      </view>
      <view class="form-item">
        <text class="form-label">证件编号</text>
        <input class="form-input" type="text" placeholder="请输入证件编号" value="{{credentialNumber}}" bindinput="onNumberInput" />
      </view>
      <view class="form-item">
        <text class="form-label">{{issuingAuthorityLabel || '签发机构'}}</text>
        <input class="form-input" type="text" placeholder="{{issuingAuthorityLabel === '学校' ? '请输入学校名称' : '请输入签发机构'}}" value="{{issuingAuthority}}" bindinput="onIssuingAuthorityInput" />
      </view>
      <view class="form-item" wx:if="{{showSkillLevel}}">
        <text class="form-label">技能等级</text>
        <input class="form-input" type="text" placeholder="如：初级/中级/高级/母婴护理师" value="{{skillLevel}}" bindinput="onSkillLevelInput" />
      </view>
      <view class="form-item">
        <text class="form-label">有效期至</text>
        <input class="form-input" type="text" placeholder="如：2028-12-31" value="{{expireDate}}" bindinput="onExpireDateInput" />
      </view>
    </view>

    <!-- 技能证书关联技能选择 -->
    <view class="card" wx:if="{{showSkillPicker && staffSkills.length > 0}}">
      <view class="card-title">关联服务技能（至少选一项）</view>
      <view class="skill-tags">
        <view
          class="skill-tag {{selectedSkillIds.indexOf(item.id) > -1 ? 'skill-tag-active' : ''}}"
          wx:for="{{staffSkills}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.categoryName}}"
          bindtap="onSkillToggle"
        >
          <text>{{item.categoryName}}</text>
        </view>
      </view>
      <view wx:if="{{selectedSkillNames.length > 0}}" class="selected-skills">
        <text class="selected-label">已选：</text>
        <text wx:for="{{selectedSkillNames}}" wx:key="*this" wx:for-item="name">{{name}} </text>
      </view>
      <view wx:else class="no-skill-hint">
        <text>请选择此技能证书对应的服务技能</text>
      </view>
    </view>

    <!-- 证件图片上传 -->
    <view class="upload-section">
      <text class="upload-label">证件图片</text>
      <view class="upload-area" bindtap="handleUploadImage">
        <image wx:if="{{fileUrl || filePath}}" class="upload-preview" src="{{fileUrl || filePath}}" mode="aspectFit"></image>
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">点击上传证件图片</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <view class="form-item">
        <text class="form-label">备注</text>
        <input class="form-input" type="text" placeholder="可选备注信息" value="{{remark}}" bindinput="onRemarkInput" />
      </view>
    </view>

    <!-- 审核状态（编辑模式） -->
    <view class="card" wx:if="{{isEdit}}">
      <view class="status-display">
        <text class="status-label">审核状态：</text>
        <text class="status-value {{status === 'approved' ? 'success' : (status === 'rejected' ? 'error' : 'warning')}}">
          {{statusLabel}}
        </text>
      </view>
    </view>
  </scroll-view>

  <view class="form-submit-bar">
    <button class="btn-primary" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="handleSave">
      保存
    </button>
  </view>
</view>
