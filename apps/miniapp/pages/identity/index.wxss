.identity-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20px 15px;
  box-sizing: border-box;
}

.identity-card {
  background-color: #fff;
  border-radius: 8px;
  padding: 24px 18px;
}

.identity-icon {
  width: 64px;
  height: 64px;
  margin: 0 auto 14px;
  border-radius: 32px;
  background-color: #e8f8e8;
  color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 600;
}

.identity-title {
  display: block;
  text-align: center;
  font-size: 20px;
  font-weight: 600;
  color: #333;
  margin-bottom: 10px;
}

.identity-desc {
  display: block;
  text-align: center;
  font-size: 13px;
  color: #777;
  line-height: 1.6;
  margin-bottom: 24px;
}

.identity-row {
  display: flex;
  align-items: center;
  padding: 13px 0;
  border-top: 1px solid #f0f0f0;
}

.identity-label {
  width: 82px;
  color: #666;
  font-size: 14px;
}

.identity-value {
  flex: 1;
  text-align: right;
  font-size: 14px;
  color: #333;
}

.identity-value.verified {
  color: #07c160;
}

.identity-value.unverified {
  color: #faad14;
}

.identity-button {
  margin-top: 28px;
}
