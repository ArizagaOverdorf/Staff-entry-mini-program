<view class="account-container">
  <view class="user-card">
    <view class="user-avatar">
      <image wx:if="{{accountAvatarUrl}}" src="{{accountAvatarUrl}}" mode="aspectFill" />
      <view wx:else class="user-avatar-text">{{accountAvatarText}}</view>
    </view>
    <view class="user-info">
      <text class="user-name">{{accountInfo.name || '家政人员'}}</text>
      <text class="user-phone">{{accountInfo.phone || '未绑定手机号'}}</text>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-title">账号安全</view>
    <view class="list-item" bindtap="handleChangePhone">
      <text class="list-item-label">修改手机号</text>
      <text class="list-item-value">{{accountInfo.identityVerified ? '已实名可自助修改' : '需先实名认证'}}</text>
      <view class="icon-arrow"></view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-title">协议与服务</view>
    <view class="list-item" bindtap="handleUserAgreement">
      <text class="list-item-label">用户服务协议</text>
      <view class="icon-arrow"></view>
    </view>
    <view class="list-item" bindtap="handlePrivacyPolicy">
      <text class="list-item-label">隐私政策</text>
      <view class="icon-arrow"></view>
    </view>
    <view class="list-item" bindtap="handleAbout">
      <text class="list-item-label">关于我们</text>
      <view class="icon-arrow"></view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-title">本地设置</view>
    <view class="list-item" bindtap="handleClearCache">
      <text class="list-item-label">清除缓存</text>
      <text class="list-item-value">{{cacheSizeText}}</text>
      <view class="icon-arrow"></view>
    </view>
  </view>

  <view class="logout-section">
    <button class="btn-secondary logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>
</view>
