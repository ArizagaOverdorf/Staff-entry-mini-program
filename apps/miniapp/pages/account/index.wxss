.account-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30px;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 30px 20px;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
}

.user-avatar {
  width: 56px;
  height: 56px;
  border-radius: 28px;
  background-color: rgba(255, 255, 255, 0.3);
  overflow: hidden;
  margin-right: 14px;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 4px;
}

.user-phone {
  display: block;
  font-size: 13px;
  opacity: 0.85;
}

/* 设置区域 */
.settings-section {
  background: #fff;
  margin-top: 10px;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background-color: #fafafa;
}

.list-item-label {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.list-item-value {
  font-size: 13px;
  color: #999;
  margin-right: 8px;
}

.list-item-arrow {
  width: 14px;
  height: 14px;
}

/* 退出登录 */
.logout-section {
  margin-top: 30px;
  padding: 0 20px;
}

.logout-btn {
  color: #f56c6c;
  border-color: #f56c6c;
}
