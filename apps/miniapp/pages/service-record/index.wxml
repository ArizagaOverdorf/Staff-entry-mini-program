<view class="service-record-container">
  <view class="list-header">
    <view>
      <text class="list-header-title">服务记录</text>
      <text class="list-header-subtitle">按订单记录历史服务表现</text>
    </view>
    <text class="list-header-count" wx:if="{{records.length > 0}}">共 {{records.length}} 条</text>
  </view>

  <view class="demo-tip" wx:if="{{usingDemo}}">
    当前暂无真实服务记录，以下为展示样例。
  </view>

  <view class="record-list" wx:if="{{records.length > 0}}">
    <view class="record-card" wx:for="{{records}}" wx:key="id">
      <view class="record-card-top">
        <text class="record-project">{{item.projectText}}</text>
        <text class="record-amount">{{item.amountText}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">日期</text>
        <text class="record-value">{{item.dateText}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">地址</text>
        <text class="record-value">{{item.addressText}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">项目</text>
        <text class="record-value">{{item.projectText}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">时长</text>
        <text class="record-value">{{item.durationText}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">金额</text>
        <text class="record-value amount">{{item.amountText}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">是否违规</text>
        <text class="record-value {{item.violation ? 'violation-yes' : 'violation-no'}}">{{item.violationText}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{loaded && records.length === 0}}">
    <view class="icon-empty">空</view>
    <text>暂无服务记录</text>
  </view>

  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>

  <view class="load-more" wx:if="{{hasMore}}">
    <text>上拉加载更多</text>
  </view>
</view>
