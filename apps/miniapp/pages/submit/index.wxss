.submit-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.submit-scroll {
  flex: 1;
}

.submit-notice {
  display: flex;
  align-items: flex-start;
  background-color: #e8f0fe;
  padding: 10px 15px;
  margin: 10px 15px;
  border-radius: 6px;
}

.notice-icon {
  width: 18px;
  height: 18px;
  line-height: 18px;
  text-align: center;
  background-color: #1989fa;
  color: #fff;
  border-radius: 50%;
  font-size: 12px;
  font-weight: 600;
  margin-right: 8px;
  flex-shrink: 0;
}

.notice-text {
  font-size: 13px;
  color: #1989fa;
  line-height: 1.4;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.card-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 10px;
  display: block;
}

.card-action {
  font-size: 13px;
  color: #07c160;
  padding: 2px 6px;
}

.card-action:active {
  opacity: 0.7;
}

.summary-info {
  border-top: 1px solid #f0f0f0;
}

.summary-row {
  display: flex;
  padding: 10px 0;
  border-bottom: 1px solid #f5f5f5;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  width: 80px;
  font-size: 13px;
  color: #666;
  flex-shrink: 0;
}

.summary-value {
  flex: 1;
  font-size: 13px;
  color: #333;
  text-align: right;
}

.summary-value.success {
  color: #07c160;
}

.rules {
  border-top: 1px solid #f0f0f0;
  padding-top: 10px;
}

.rule-item {
  display: block;
  font-size: 13px;
  color: #666;
  line-height: 1.8;
}

.mandatory-list {
  border-top: 1px solid #f0f0f0;
  padding-top: 8px;
}

.mandatory-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f5f5f5;
}

.mandatory-item:last-child {
  border-bottom: none;
}

.mandatory-label {
  font-size: 13px;
  color: #333;
}

.mandatory-status {
  font-size: 12px;
  font-weight: 500;
}

.status-approved {
  color: #07c160;
}

.status-pending {
  color: #faad14;
}

.status-rejected {
  color: #f56c6c;
}

.status-missing {
  color: #f56c6c;
}

.submit-footer {
  padding: 10px 0 30px;
  background-color: #fff;
  border-top: 1px solid #f0f0f0;
}
