.message-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20px;
}

/* ---- Audit progress summary row ---- */

.audit-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 15px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 8px;
}

.audit-summary:active {
  background-color: #fafafa;
}

.audit-summary-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.audit-summary-avatar {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  background-color: #fff7e6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
}

.audit-summary-avatar-text {
  font-size: 18px;
  color: #faad14;
  font-weight: 700;
}

.audit-summary-content {
  flex: 1;
  min-width: 0;
}

.audit-summary-top {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.audit-summary-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-right: 8px;
}

.audit-summary-status {
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 3px;
  background-color: #f5f5f5;
  color: #999;
}

.audit-summary-status.pending_review,
.audit-summary-status.needs_more_info {
  background-color: #fff7e6;
  color: #fa8c16;
}

.audit-summary-status.approved {
  background-color: #e8f8e8;
  color: #07c160;
}

.audit-summary-status.rejected {
  background-color: #fff1f0;
  color: #f56c6c;
}

.audit-summary-preview {
  display: block;
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.audit-summary-right {
  margin-left: 10px;
  flex-shrink: 0;
}

.audit-summary-arrow {
  font-size: 16px;
  color: #ccc;
}

/* ---- Support conversation summary row ---- */

.support-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 15px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 8px;
}

.support-summary:active {
  background-color: #fafafa;
}

.support-summary-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.support-summary-avatar {
  width: 44px;
  height: 44px;
  border-radius: 4px;
  background-color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
}

.support-summary-avatar-text {
  font-size: 14px;
  color: #fff;
  font-weight: 500;
}

.support-summary-content {
  flex: 1;
  min-width: 0;
}

.support-summary-top {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.support-summary-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-right: 8px;
}

.support-summary-status {
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 3px;
}

.support-summary-status.status-active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.support-summary-status.status-ended {
  background-color: #f5f5f5;
  color: #999;
}

.support-summary-preview {
  display: block;
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.support-summary-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 10px;
  flex-shrink: 0;
}

.support-summary-time {
  font-size: 11px;
  color: #ccc;
  margin-bottom: 4px;
}

.support-summary-badge {
  min-width: 18px;
  height: 18px;
  border-radius: 9px;
  background-color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}

.support-summary-badge text {
  font-size: 10px;
  color: #fff;
  line-height: 1;
}

/* ---- Support entry ---- */

.support-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 15px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 8px;
}

.support-entry:active {
  background-color: #fafafa;
}

.support-entry-text {
  font-size: 14px;
  color: #07c160;
  font-weight: 500;
}

.support-entry-arrow {
  font-size: 14px;
  color: #ccc;
}

/* ---- Toolbar ---- */

.message-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 15px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.toolbar-info {
  font-size: 13px;
  color: #999;
}

.toolbar-action {
  font-size: 13px;
  color: #07c160;
}

.toolbar-action:active {
  opacity: 0.7;
}

/* ---- Message list ---- */

.message-list {
  background-color: #fff;
}

.message-item {
  display: flex;
  align-items: flex-start;
  padding: 14px 15px;
  border-bottom: 1px solid #f5f5f5;
}

.message-item:active {
  background-color: #fafafa;
}

.message-item.unread {
  background-color: #f0fff5;
}

.msg-indicator {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: #07c160;
  margin-right: 10px;
  margin-top: 6px;
  flex-shrink: 0;
}

.msg-content {
  flex: 1;
  min-width: 0;
}

.msg-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.msg-title {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 8px;
}

.msg-time {
  font-size: 11px;
  color: #ccc;
  flex-shrink: 0;
}

.msg-preview {
  display: block;
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

/* ---- Empty / Loading ---- */

.empty-state {
  text-align: center;
  padding: 80px 0;
  color: #999;
  font-size: 15px;
}

.loading-container {
  text-align: center;
  padding: 40px 0;
  color: #999;
  font-size: 14px;
}

.load-more {
  text-align: center;
  padding: 16px;
  color: #999;
  font-size: 13px;
  background-color: #fff;
}
