<view class="support-chat-container">
  <!-- Chat messages -->
  <scroll-view
    class="chat-scroll"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="chat-list">
      <view
        class="chat-msg {{item.styleClass}}"
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{index}}"
      >
        <view class="chat-msg-sender">{{item.senderLabel}}</view>
        <view class="chat-msg-bubble">
          <!-- Media image preview -->
          <image
            wx:if="{{item.isMedia && item.mediaType === 'image' && item.mediaUrl && !item.mediaLoadFailed}}"
            class="chat-media-img"
            src="{{item.mediaUrl}}"
            mode="aspectFill"
            data-url="{{item.mediaUrl}}"
            data-index="{{index}}"
            data-file-id="{{item.mediaFileId}}"
            data-type="image"
            bindtap="onPreviewMedia"
            binderror="onMediaImageError"
          />
          <view wx:elif="{{item.isMedia && item.mediaType === 'image'}}" class="chat-media-fallback">
            <text>[图片]</text>
          </view>
          <!-- Media video placeholder -->
          <view
            wx:elif="{{item.isMedia && item.mediaType === 'video'}}"
            class="chat-media-video"
            data-url="{{item.mediaUrl}}"
            data-type="video"
            bindtap="onPreviewMedia"
          >
            <text>[视频] {{item.displayContent}}</text>
          </view>
          <view
            wx:elif="{{item.isMedia && item.mediaType === 'file'}}"
            class="chat-media-file"
            data-url="{{item.mediaUrl}}"
            data-file-name="{{item.displayContent}}"
            data-file-type="{{item.mediaFileType}}"
            bindtap="onOpenMediaFile"
          >
            <text class="chat-media-file-icon">[file]</text>
            <text class="chat-media-file-name">{{item.displayContent}}</text>
          </view>
          <!-- Text message -->
          <text wx:else class="chat-msg-text">{{item.displayContent}}</text>
        </view>
        <view class="chat-msg-time">{{item.time}}</view>
      </view>
    </view>

    <!-- Empty state -->
    <view class="chat-empty" wx:if="{{loaded && messages.length === 0}}">
      <text class="chat-empty-text">暂无消息</text>
      <text class="chat-empty-hint">输入消息开始咨询</text>
    </view>

    <!-- Loading -->
    <view class="chat-loading" wx:if="{{!loaded}}">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <!-- Input bar: fixed bottom, WeChat-style -->
  <view class="chat-input-bar">
    <!-- Voice button -->
    <view class="chat-tool-btn" bindtap="onTapVoice">
      <view class="chat-voice-icon">
        <view class="chat-voice-head"></view>
        <view class="chat-voice-stem"></view>
      </view>
    </view>

    <!-- Textarea input -->
    <view class="chat-textarea-wrapper">
      <textarea
        class="chat-textarea"
        placeholder="输入消息..."
        value="{{inputContent}}"
        maxlength="{{500}}"
        bindinput="onInputChange"
        bindlinechange="onTextareaLineChange"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        confirm-type="send"
        bindconfirm="sendMessage"
        auto-height
        fixed
        cursor-spacing="10"
      />
    </view>

    <!-- Plus button -->
    <view class="chat-tool-btn" bindtap="onTapPlus">
      <text class="chat-tool-icon">+</text>
    </view>

  </view>

  <!-- Action sheet for media picker -->
  <view class="action-sheet-mask" wx:if="{{showActionSheet}}" bindtap="onCloseActionSheet"></view>
  <view class="action-sheet {{showActionSheet ? 'action-sheet-show' : ''}}">
    <view class="action-sheet-title">发送内容</view>
    <view class="action-sheet-item" bindtap="onChooseImage">
      <text class="action-sheet-label">照片 (最大2MB)</text>
    </view>
    <view class="action-sheet-item" bindtap="onChooseVideo">
      <text class="action-sheet-label">视频 (最大5MB)</text>
    </view>
    <view class="action-sheet-item" bindtap="onChooseFile">
      <text class="action-sheet-label">文件 (最大10MB)</text>
    </view>
    <view class="action-sheet-cancel" bindtap="onCloseActionSheet">
      <text>取消</text>
    </view>
  </view>
</view>
