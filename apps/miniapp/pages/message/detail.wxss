.detail-container {
  min-height: 100vh;
  background-color: #fff;
  padding: 20px 16px;
}

.detail-header {
  text-align: center;
  padding-bottom: 20px;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 20px;
}

.detail-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
  line-height: 1.4;
}

.detail-time {
  font-size: 12px;
  color: #ccc;
}

.detail-body {
  line-height: 1.8;
}

.detail-content {
  font-size: 15px;
  color: #333;
  line-height: 1.8;
}
