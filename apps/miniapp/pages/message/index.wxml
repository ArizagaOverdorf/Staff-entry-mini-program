<view class="message-container">
  <!-- 顶部操作栏 -->
  <view class="message-toolbar" wx:if="{{messages.length > 0 && totalUnread > 0}}">
    <text class="toolbar-info">未读消息 {{totalUnread}} 条</text>
    <text class="toolbar-action" bindtap="markAllRead">全部标记已读</text>
  </view>

  <!-- 消息列表 -->
  <view class="message-list" wx:if="{{messages.length > 0}}">
    <view
      class="message-item {{item.status === 'unread' ? 'unread' : ''}}"
      wx:for="{{messages}}"
      wx:key="id"
      data-item="{{item}}"
      bindtap="viewDetail"
    >
      <view class="msg-indicator" wx:if="{{item.status === 'unread'}}"></view>
      <view class="msg-content">
        <view class="msg-top">
          <text class="msg-title">{{item.title || '消息'}}</text>
          <text class="msg-time">{{formatTime(item.createdAt)}}</text>
        </view>
        <text class="msg-preview">{{item.content || item.preview || ''}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{loaded && messages.length === 0}}">
    <view class="icon-empty">空</view>
    <text>暂无消息</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text>上拉加载更多</text>
  </view>
</view>
