.support-chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
  background-color: #f5f5f5;
  position: relative;
}

/* ---- Chat scroll area ---- */

.chat-scroll {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 12px;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
}

.chat-list {
  padding-bottom: 8px;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

/* ---- Chat message ---- */

.chat-msg {
  margin-bottom: 16px;
  display: flex;
  flex-direction: column;
  max-width: 75%;
  box-sizing: border-box;
}

.chat-msg.msg-left {
  align-items: flex-start;
}

.chat-msg.msg-right {
  align-items: flex-end;
  margin-left: auto;
}

.chat-msg-sender {
  font-size: 15px;
  color: #999;
  margin-bottom: 4px;
  padding: 0 4px;
}

.chat-msg-bubble {
  padding: 12px 15px;
  border-radius: 8px;
  word-break: break-word;
  max-width: 100%;
  box-sizing: border-box;
}

.msg-left .chat-msg-bubble {
  background-color: #fff;
  border: 1px solid #e8e8e8;
}

.msg-right .chat-msg-bubble {
  background-color: #95ec69;
  border: 1px solid #7ddb5a;
}

.chat-msg-text {
  font-size: 17px;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-all;
  max-width: 100%;
  box-sizing: border-box;
}

.chat-msg-time {
  font-size: 13px;
  color: #bbb;
  margin-top: 4px;
  padding: 0 4px;
}

/* ---- Media messages ---- */

.chat-media-img {
  width: 180px;
  height: 130px;
  border-radius: 4px;
  display: block;
  background: #f2f2f2;
}

.chat-media-fallback {
  width: 180px;
  height: 96px;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.35);
  color: #333;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-media-video {
  font-size: 14px;
  color: #666;
  padding: 8px 12px;
}

.chat-media-file {
  min-width: 180px;
  max-width: 220px;
  min-height: 54px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px;
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.45);
  box-sizing: border-box;
}

.chat-media-file-icon {
  font-size: 22px;
  flex-shrink: 0;
}

.chat-media-file-name {
  font-size: 15px;
  color: #333;
  word-break: break-all;
}

/* ---- Empty / Loading ---- */

.chat-empty {
  text-align: center;
  padding: 80px 0;
  color: #999;
  font-size: 15px;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.chat-empty-text {
  display: block;
  margin-bottom: 8px;
}

.chat-empty-hint {
  display: block;
  font-size: 13px;
  color: #bbb;
}

.chat-loading {
  text-align: center;
  padding: 40px 0;
  color: #999;
  font-size: 14px;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

/* ---- Input bar (fixed bottom) ---- */

.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 8px 6px;
  background-color: #f7f7f7;
  border-top: 1px solid #e0e0e0;
  gap: 4px;
  flex-shrink: 0;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.chat-tool-btn {
  width: 32px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat-tool-btn:first-child {
  margin-left: 6px;
}

.chat-tool-btn:last-child {
  margin-right: 6px;
}

.chat-tool-icon {
  font-size: 30px;
  line-height: 48px;
  color: #333;
  font-weight: 300;
}

.chat-voice-icon {
  width: 28px;
  height: 28px;
  position: relative;
  flex-shrink: 0;
}

.chat-voice-head {
  position: absolute;
  left: 9px;
  top: 4px;
  width: 10px;
  height: 15px;
  border: 2px solid #333;
  border-radius: 8px;
  box-sizing: border-box;
}

.chat-voice-stem {
  position: absolute;
  left: 6px;
  top: 12px;
  width: 16px;
  height: 12px;
  border: 2px solid #333;
  border-top: none;
  border-radius: 0 0 10px 10px;
  box-sizing: border-box;
}

.chat-voice-stem::after {
  content: '';
  position: absolute;
  left: 5px;
  bottom: -6px;
  width: 2px;
  height: 6px;
  background: #333;
}

.chat-textarea-wrapper {
  flex: 1 1 0;
  min-width: 0;
  box-sizing: border-box;
}

.chat-textarea {
  width: 100%;
  min-height: 48px;
  max-height: 120px;
  font-size: 17px;
  line-height: 1.45;
  background-color: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  padding: 8px 10px;
  box-sizing: border-box;
}

/* ---- Action sheet ---- */

.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 12px 12px 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.25s ease;
}

.action-sheet-show {
  transform: translateY(0);
}

.action-sheet-title {
  text-align: center;
  font-size: 13px;
  color: #999;
  padding: 14px 0 10px;
  border-bottom: 1px solid #f0f0f0;
}

.action-sheet-item {
  padding: 16px;
  text-align: center;
  font-size: 16px;
  color: #333;
  border-bottom: 1px solid #f0f0f0;
}

.action-sheet-item:active {
  background-color: #f5f5f5;
}

.action-sheet-cancel {
  padding: 16px;
  text-align: center;
  font-size: 16px;
  color: #333;
  font-weight: 500;
  margin-top: 6px;
  border-top: 6px solid #f0f0f0;
}

.action-sheet-cancel:active {
  background-color: #f5f5f5;
}
