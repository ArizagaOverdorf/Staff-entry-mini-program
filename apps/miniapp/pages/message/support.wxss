.support-form-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 16px;
}

.form-section {
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.form-label {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 10px;
}

.form-input {
  width: 100%;
  height: 44px;
  font-size: 14px;
  border: 1px solid #e8e8e8;
  border-radius: 4px;
  padding: 0 12px;
  box-sizing: border-box;
  background-color: #fafafa;
}

.form-textarea {
  width: 100%;
  min-height: 160px;
  font-size: 14px;
  border: 1px solid #e8e8e8;
  border-radius: 4px;
  padding: 12px;
  box-sizing: border-box;
  background-color: #fafafa;
}

.form-footer {
  margin-top: 24px;
}

.submit-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background-color: #07c160;
  color: #fff;
  font-size: 16px;
  border-radius: 8px;
  border: none;
}

.submit-btn[disabled] {
  background-color: #a0d9b1;
}
