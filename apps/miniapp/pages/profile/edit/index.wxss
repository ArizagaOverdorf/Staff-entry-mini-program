.profile-edit-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  flex: 1;
}

.form-section {
  margin-bottom: 10px;
}

.form-section-header {
  padding: 12px 15px 6px;
  font-size: 14px;
  font-weight: 500;
  color: #666;
}

.form-group {
  background: #fff;
  padding: 0 15px;
}

.avatar-row {
  display: flex;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #eee;
}

.profile-avatar {
  width: 56px;
  height: 56px;
  border-radius: 28px;
  overflow: hidden;
  background-color: #e8f8e8;
  margin-right: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-avatar-text {
  color: #07c160;
  font-size: 22px;
  font-weight: 600;
}

.avatar-action {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.avatar-title {
  font-size: 15px;
  color: #333;
  margin-bottom: 4px;
}

.avatar-desc {
  font-size: 12px;
  color: #1989fa;
}

.form-readonly {
  color: #999;
}

/* Bottom buttons */
.form-submit-bar {
  padding: 8px 15px 30px;
  background-color: #fff;
  border-top: 1px solid #f0f0f0;
}

.auto-save-status {
  min-height: 18px;
  line-height: 18px;
  margin-bottom: 6px;
  text-align: center;
  font-size: 12px;
  color: #999;
}

.btn-submit {
  width: 100%;
}

/* ── Requirement cards ── */

.requirement-card {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-top: 1px solid #f5f5f5;
}

.requirement-card:first-of-type {
  border-top: none;
}

.optional-card {
  min-height: 66px;
}

.requirement-main {
  flex: 1;
  min-width: 0;
  padding-right: 10px;
}

.requirement-title {
  display: block;
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.requirement-desc {
  display: block;
  font-size: 12px;
  color: #888;
  line-height: 1.4;
}

.requirement-files {
  display: block;
  font-size: 12px;
  color: #07c160;
  margin-top: 4px;
}

.requirement-side {
  width: 78px;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.requirement-action {
  font-size: 12px;
  color: #1989fa;
  margin-top: 8px;
}

.requirement-card:active {
  background-color: #fafafa;
}

/* ── Skill entry cards ── */

.skill-entry-card {
  margin-top: 10px;
  padding: 0;
  border-radius: 6px;
  overflow: hidden;
}

.skill-entry-card:first-child {
  margin-top: 0;
}

.skill-entry-summary {
  padding: 12px 14px;
  background: #fafafa;
  border: 1px solid #eee;
  border-radius: 6px;
}

.skill-entry-summary:active {
  background: #f0f0f0;
}

.skill-entry-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.skill-entry-title {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.skill-entry-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 10px;
}

.skill-entry-detail {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #eee;
}

.skill-entry-name {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 4px;
}

.skill-entry-level {
  display: inline-block;
  font-size: 12px;
  color: #666;
  margin-right: 12px;
  padding: 2px 6px;
  background: #f0f0f0;
  border-radius: 3px;
}

.skill-entry-duration {
  display: inline-block;
  font-size: 12px;
  color: #666;
  margin-right: 12px;
}

.skill-entry-related {
  display: block;
  font-size: 12px;
  color: #07c160;
  margin-top: 4px;
}

.skill-entry-files {
  display: block;
  font-size: 12px;
  color: #666;
  margin-top: 4px;
}

.skill-entry-hint {
  margin-top: 4px;
  font-size: 12px;
  color: #bbb;
}

.skill-entry-actions {
  margin-top: 8px;
  text-align: right;
}

.skill-entry-clear {
  font-size: 12px;
  color: #f56c6c;
  padding: 4px 8px;
}

/* ── Skill entry editor ── */

.skill-entry-editor {
  padding: 14px;
  background: #fff;
  border: 1px solid #07c160;
  border-radius: 6px;
}

.editor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 1px solid #f0f0f0;
}

.editor-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.editor-cancel {
  font-size: 13px;
  color: #999;
}

.editor-footer {
  margin-top: 14px;
  padding-top: 10px;
  border-top: 1px solid #f0f0f0;
}

/* ── Upload images in editor ── */

.upload-section {
  margin-top: 10px;
}

.upload-label {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
}

.upload-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.upload-image-item {
  width: 80px;
  height: 80px;
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}

.upload-thumb {
  width: 100%;
  height: 100%;
}

.upload-thumb-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f7fa;
  color: #999;
  font-size: 12px;
}

.upload-remove {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 22px;
  height: 22px;
  background: #f56c6c;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  line-height: 1;
}

.upload-add-btn {
  width: 80px;
  height: 80px;
  border: 1px dashed #ddd;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-add-icon {
  font-size: 32px;
  color: #ccc;
}

/* ── Skill tags ── */

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}

.skill-tag {
  padding: 5px 10px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 12px;
  color: #666;
  background: #fafafa;
}

.skill-tag-active {
  border-color: #07c160;
  color: #07c160;
  background: #f0fff4;
}

.selected-skills {
  margin-top: 8px;
  font-size: 12px;
  color: #07c160;
}

.selected-label {
  color: #666;
}

/* ── Tag styles ── */

.tag-warning {
  color: #e6a23c;
  background: #fdf6ec;
}

.tag-success {
  color: #67c23a;
  background: #f0f9eb;
}

.tag-error {
  color: #f56c6c;
  background: #fef0f0;
}

.tag-info {
  color: #909399;
  background: #f4f4f5;
}

.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.form-picker {
  min-height: 30px;
  line-height: 30px;
}

.form-placeholder {
  color: #999;
}

/* ── Address selector ── */

.address-picker-value {
  min-height: 30px;
  line-height: 30px;
  text-align: right;
  color: #333;
}

.address-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: flex-end;
}

.address-panel {
  width: 100%;
  height: 72vh;
  background: #fff;
  border-top-left-radius: 8px;
  border-top-right-radius: 8px;
  overflow: hidden;
}

.address-panel-header {
  height: 48px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #eee;
}

.address-panel-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.address-panel-close {
  font-size: 14px;
  color: #1989fa;
}

.address-columns {
  height: calc(72vh - 48px);
  display: flex;
}

.address-column {
  height: 100%;
}

.address-region-column {
  width: 42%;
  background: #f7f8fa;
}

.address-city-column {
  width: 58%;
  background: #fff;
}

.address-option {
  min-height: 44px;
  line-height: 44px;
  padding: 0 14px;
  font-size: 15px;
  color: #333;
  border-bottom: 1px solid #f0f0f0;
  box-sizing: border-box;
}

.address-option-active {
  color: #07c160;
  font-weight: 600;
  background: #fff;
}

.address-city-title {
  height: 36px;
  line-height: 36px;
  padding: 0 14px;
  font-size: 12px;
  color: #999;
  background: #fafafa;
  border-bottom: 1px solid #f0f0f0;
}

.address-city-option {
  background: #fff;
}
