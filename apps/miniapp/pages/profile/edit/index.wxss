.profile-edit-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  flex: 1;
}

.form-section {
  margin-bottom: 10px;
}

.form-section-header {
  padding: 12px 15px 6px;
  font-size: 14px;
  font-weight: 500;
  color: #666;
}

.form-submit-bar {
  padding: 10px 0 30px;
  background-color: #fff;
  border-top: 1px solid #f0f0f0;
}
