<view class="profile-edit-container">
  <scroll-view class="form-scroll" scroll-y>
    <view class="form-section">
      <view class="form-section-header">基本信息</view>
      <view class="form-group">
        <view class="avatar-row">
          <view class="profile-avatar" bindtap="handleAvatarUpload">
            <image wx:if="{{avatarPreviewUrl || avatarUrl}}" src="{{avatarPreviewUrl || avatarUrl}}" mode="aspectFill" bindload="onAvatarImageLoad" binderror="onAvatarImageError" />
            <text wx:else class="profile-avatar-text">{{avatarText}}</text>
          </view>
          <view class="avatar-action" bindtap="handleAvatarUpload">
            <text class="avatar-title">头像</text>
            <text class="avatar-desc">点击更换头像（拍照或相册）</text>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">姓名</text>
          <input class="form-input" type="text" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" maxlength="30" />
        </view>
        <view class="form-item">
          <text class="form-label">性别</text>
          <picker range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" bindchange="onGenderChange">
            <view class="form-value">{{genderLabel}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">出生日期</text>
          <text class="form-value">{{birthday || '请先在证件管理中填写身份证号'}}</text>
        </view>
        <view class="form-item">
          <text class="form-label">手机号</text>
          <text class="form-value">{{phone || '暂无'}}</text>
        </view>
        <view class="form-item">
          <text class="form-label">家庭住址</text>
          <input class="form-input" type="text" placeholder="请输入家庭住址" value="{{address}}" bindinput="onAddressInput" />
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-section-header">服务信息</view>
      <view class="form-group">
        <view class="form-item">
          <text class="form-label">服务类别</text>
          <view class="form-value">
            <category-picker categories="{{serviceCategories}}" selectedValues="{{selectedCategories}}" bind:change="onCategoryChange" />
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">服务区域</text>
          <view class="form-value">
            <area-picker areas="{{serviceAreas}}" selectedValues="{{selectedAreas}}" bind:change="onAreaChange" />
          </view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-section-header">紧急联系人</view>
      <view class="form-group">
        <view class="form-item">
          <text class="form-label">联系人姓名</text>
          <input class="form-input" type="text" placeholder="请输入紧急联系人" value="{{emergencyContact}}" bindinput="onEmergencyContactInput" maxlength="30" />
        </view>
        <view class="form-item">
          <text class="form-label">联系人电话</text>
          <input class="form-input" type="number" placeholder="请输入紧急联系电话" value="{{emergencyPhone}}" bindinput="onEmergencyPhoneInput" maxlength="11" />
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="form-submit-bar">
    <button class="btn-primary" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="handleSave">
      保存
    </button>
  </view>
</view>
