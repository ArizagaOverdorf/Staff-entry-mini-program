<view class="profile-view-container">
  <view class="card">
    <view class="card-header">
      <text class="card-title">基本信息</text>
      <text class="card-action" bindtap="goToEdit">编辑</text>
    </view>
    <view class="profile-avatar-row" bindtap="goToEdit">
      <view class="profile-avatar">
        <image wx:if="{{profile.avatarUrl}}" src="{{profile.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="profile-avatar-text">{{avatarText}}</text>
      </view>
      <view class="profile-avatar-info">
        <text class="profile-avatar-title">头像</text>
        <text class="profile-avatar-desc">点击编辑资料后可拍照或从相册上传</text>
      </view>
      <view class="icon-arrow"></view>
    </view>
    <view class="profile-info">
      <view class="info-row">
        <text class="info-label">姓名</text>
        <text class="info-value">{{profile.name || '未填写'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">身份证号</text>
        <text class="info-value">{{profile.idNumber || '未填写'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">性别</text>
        <text class="info-value">{{profile.genderLabel || '未设置'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">出生日期</text>
        <text class="info-value">{{profile.birthday || '未填写'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">手机号</text>
        <text class="info-value">{{profile.phone || '未绑定'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">家庭住址</text>
        <text class="info-value">{{profile.address || '未填写'}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">服务信息</text>
    </view>
    <view class="profile-info">
      <view class="info-row">
        <text class="info-label">服务类别</text>
        <text class="info-value">{{profile.serviceCategoryNames || '未选择'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">服务区域</text>
        <text class="info-value">{{profile.serviceAreaNames || '未选择'}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">紧急联系人</text>
    </view>
    <view class="profile-info">
      <view class="info-row">
        <text class="info-label">联系人</text>
        <text class="info-value">{{profile.emergencyContact || '未填写'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">联系电话</text>
        <text class="info-value">{{profile.emergencyPhone || '未填写'}}</text>
      </view>
    </view>
  </view>

  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>
</view>
