<view class="home-container">
  <view class="home-header">
    <view class="header-top">
      <view class="header-user">
        <view class="avatar">
          <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill" bindload="onAvatarImageLoad" binderror="onAvatarImageError" />
          <view wx:else class="avatar-text">{{staffAvatarText}}</view>
        </view>
        <view class="header-info">
          <view class="header-name-row">
            <text class="header-name">{{displayName}}</text>
            <text class="identity-badge {{identityVerified ? 'verified' : 'unverified'}}" bindtap="goToIdentity">{{identityVerifiedLabel}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="status-cards">
      <view class="status-card">
        <text class="status-card-label">等级称号</text>
        <text class="status-card-value">开发中</text>
        <text class="status-card-hint">信用分：开发中</text>
      </view>
      <view class="status-card status-card-clickable online-status-card {{onlineStatusClass}}" bindtap="toggleOnlineStatus">
        <text class="status-card-label">上线状态</text>
        <text class="status-card-value {{onlineStatusClass}}">{{onlineStatusLabel}}</text>
        <text class="status-card-hint">{{onlineNextAction}}</text>
      </view>
    </view>
  </view>

  <view class="home-grid">
    <view class="grid-cell">
      <view class="grid-action" bindtap="goToProfile">
        <view class="grid-icon icon-profile"><view class="icon-head"></view><view class="icon-body"></view></view>
        <text class="grid-label">个人资料</text>
      </view>
    </view>
    <view class="grid-cell">
      <view class="grid-action" bindtap="goToResume">
        <view class="grid-icon icon-resume"><view class="icon-paper"></view><view class="icon-lines"></view></view>
        <text class="grid-label">我的简历</text>
      </view>
    </view>
    <view class="grid-cell">
      <view class="grid-action" bindtap="goToServiceRecord">
        <view class="grid-icon icon-record"><view class="icon-calendar"></view><view class="icon-dot"></view></view>
        <text class="grid-label">服务记录</text>
      </view>
    </view>
    <view class="grid-cell">
      <view class="grid-action" bindtap="goToMessage">
        <view class="grid-icon icon-message"><view class="icon-bubble"></view></view>
        <text class="grid-label">消息中心
          <text wx:if="{{unreadMsgCount > 0}}" class="grid-badge">{{unreadMsgCount}}</text>
        </text>
      </view>
    </view>
    <view class="grid-cell">
      <view class="grid-action" bindtap="goToSupport">
        <view class="grid-icon icon-service"><view class="icon-headset"></view><view class="icon-mic"></view></view>
        <text class="grid-label">联系客服</text>
      </view>
    </view>
    <view class="grid-cell">
      <view class="grid-action" bindtap="goToAccount">
        <view class="grid-icon icon-account"><view class="icon-gear"></view></view>
        <text class="grid-label">账号设置</text>
      </view>
    </view>
  </view>

  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>
</view>
