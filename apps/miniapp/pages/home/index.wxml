<view class="home-container">
  <!-- 头部状态栏 -->
  <view class="home-header">
    <view class="header-top">
      <view class="header-user">
        <view class="avatar">
          <image src="/images/avatar.png" mode="aspectFill"></image>
        </view>
        <view class="header-info">
          <text class="header-name">{{staffInfo ? staffInfo.name : '家政人员'}}</text>
          <text class="header-status">入驻状态：{{intakeStatusLabel}}</text>
        </view>
      </view>
      <view class="header-badge" bindtap="goToMessage">
        <image class="msg-icon" src="/images/message.png" mode="aspectFit"></image>
        <view class="msg-count" wx:if="{{unreadMsgCount > 0}}">{{unreadMsgCount}}</view>
      </view>
    </view>

    <!-- 快捷状态卡片 -->
    <view class="status-cards">
      <view class="status-card">
        <text class="status-card-label">入驻状态</text>
        <text class="status-card-value {{intakeStatus === 'approved' ? 'success' : (intakeStatus === 'rejected' ? 'error' : 'warning')}}">
          {{intakeStatusLabel}}
        </text>
      </view>
      <view class="status-card">
        <text class="status-card-label">上架状态</text>
        <text class="status-card-value {{listingStatus === 'on' ? 'success' : (listingStatus === 'paused' ? 'warning' : '')}}">
          {{listingStatusLabel}}
        </text>
      </view>
    </view>
  </view>

  <!-- 功能网格 -->
  <view class="home-grid">
    <view class="grid-item" bindtap="goToProfile">
      <image class="grid-icon" src="/images/profile.png" mode="aspectFit"></image>
      <text class="grid-label">个人资料</text>
    </view>
    <view class="grid-item" bindtap="goToCredentials">
      <image class="grid-icon" src="/images/credential.png" mode="aspectFit"></image>
      <text class="grid-label">证件管理</text>
    </view>
    <view class="grid-item" bindtap="goToSubmit">
      <image class="grid-icon" src="/images/submit.png" mode="aspectFit"></image>
      <text class="grid-label">提交入驻</text>
    </view>
    <view class="grid-item" bindtap="goToAudit">
      <image class="grid-icon" src="/images/audit.png" mode="aspectFit"></image>
      <text class="grid-label">审核进度</text>
    </view>
    <view class="grid-item" bindtap="goToServiceRecord">
      <image class="grid-icon" src="/images/service.png" mode="aspectFit"></image>
      <text class="grid-label">服务记录</text>
    </view>
    <view class="grid-item" bindtap="goToMessage">
      <image class="grid-icon" src="/images/message.png" mode="aspectFit"></image>
      <text class="grid-label">消息中心
        <text wx:if="{{unreadMsgCount > 0}}" class="grid-badge">{{unreadMsgCount}}</text>
      </text>
    </view>
    <view class="grid-item" bindtap="goToAccount">
      <image class="grid-icon" src="/images/account.png" mode="aspectFit"></image>
      <text class="grid-label">账号设置</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{!loaded}}">
    <text>加载中...</text>
  </view>
</view>
