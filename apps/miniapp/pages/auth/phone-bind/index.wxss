.phone-bind-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #fff;
}

.phone-bind-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96px 30px 40px;
}

.phone-bind-title {
  font-size: 20px;
  font-weight: 600;
  color: #333;
  margin-bottom: 10px;
}

.phone-bind-desc {
  font-size: 14px;
  color: #999;
  text-align: center;
}

.phone-bind-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 20px 80px;
}

.phone-input {
  box-sizing: border-box;
  width: 100%;
  height: 48px;
  margin-bottom: 16px;
  padding: 0 16px;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  font-size: 16px;
  color: #333;
  background-color: #fff;
}

.code-row {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}

.code-input {
  box-sizing: border-box;
  flex: 1;
  height: 48px;
  padding: 0 16px;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  font-size: 16px;
  color: #333;
  background-color: #fff;
}

.btn-code {
  width: 118px;
  height: 48px;
  line-height: normal;
  margin-left: 10px;
  padding: 0;
  border-radius: 8px;
  border: 1px solid #07c160;
  background-color: #fff;
  color: #07c160;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-code[disabled] {
  border-color: #ddd;
  color: #aaa;
  background-color: #f7f7f7;
}

.phone-bind-tip {
  text-align: center;
  font-size: 12px;
  color: #ccc;
  margin-top: 10px;
  padding: 0 20px;
}
