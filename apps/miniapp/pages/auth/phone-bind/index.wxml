<view class="phone-bind-container">
  <view class="phone-bind-header">
    <text class="phone-bind-title">绑定手机号</text>
    <text class="phone-bind-desc">为了保障您的账户安全，请绑定手机号</text>
  </view>

  <view class="phone-bind-body">
    <input
      class="phone-input"
      type="number"
      maxlength="11"
      value="{{phone}}"
      bindinput="handlePhoneInput"
      placeholder="请输入手机号"
    />

    <view class="code-row">
      <input
        class="code-input"
        type="number"
        maxlength="6"
        value="{{smsCode}}"
        bindinput="handleCodeInput"
        placeholder="请输入验证码"
      />
      <button
        class="btn-code"
        disabled="{{isSendingCode || countdown > 0}}"
        loading="{{isSendingCode}}"
        bindtap="handleSendCode"
      >
        {{countdown > 0 ? countdown + '秒后重发' : '获取验证码'}}
      </button>
    </view>

    <button
      class="btn-primary"
      loading="{{isBinding}}"
      disabled="{{isBinding}}"
      bindtap="handleVerifyCodeLogin"
    >
      获取验证码登录
    </button>

    <view class="phone-bind-tip">
      <text>本地测试验证码：123456。上线后接入短信服务。</text>
    </view>
  </view>
</view>
