<view class="phone-bind-container">
  <view class="phone-bind-header">
    <image class="phone-bind-icon" src="/images/phone.png" mode="aspectFit"></image>
    <text class="phone-bind-title">绑定手机号</text>
    <text class="phone-bind-desc">为了保障您的账户安全，请绑定手机号</text>
  </view>

  <view class="phone-bind-body">
    <input
      class="phone-input"
      type="number"
      maxlength="11"
      value="{{phone}}"
      bindinput="handlePhoneInput"
      placeholder="请输入手机号"
    />

    <button
      class="btn-primary"
      open-type="getPhoneNumber"
      loading="{{isBinding}}"
      disabled="{{isBinding}}"
      bindgetphonenumber="handleGetPhoneNumber"
    >
      获取手机号
    </button>

    <view class="phone-bind-tip">
      <text>我们仅用于身份验证，不会泄露您的个人信息</text>
    </view>
  </view>
</view>
