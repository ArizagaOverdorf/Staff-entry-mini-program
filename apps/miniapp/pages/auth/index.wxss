.auth-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #07c160 0%, #06ad56 42%, #f5f5f5 42%);
}

.auth-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72px 0 40px;
}

.auth-logo {
  width: 132px;
  height: 110px;
  margin-bottom: 16px;
  display: block;
}

.auth-title {
  font-size: 22px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8px;
}

.auth-desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.85);
}

.auth-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 28px 24px 60px;
  background-color: #fff;
  border-radius: 8px 8px 0 0;
}

.auth-input,
.auth-code-input {
  box-sizing: border-box;
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  font-size: 16px;
  color: #333;
  background-color: #fff;
}

.auth-input {
  margin-bottom: 14px;
}

.auth-code-row {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
}

.auth-code-input {
  flex: 1;
  min-width: 0;
}

.auth-code-button {
  width: 118px;
  height: 48px;
  line-height: normal;
  margin-left: 10px;
  padding: 0;
  border-radius: 8px;
  border: 1px solid #07c160;
  background-color: #fff;
  color: #07c160;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.auth-code-button[disabled] {
  border-color: #ddd;
  color: #aaa;
  background-color: #f7f7f7;
}

.auth-login-button {
  width: 100%;
  height: 46px;
  line-height: normal;
  margin: 18px 0 0;
  align-self: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.auth-agreement {
  width: 100%;
  font-size: 12px;
  color: #999;
  line-height: 20px;
  margin-top: 2px;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
}

.agreement-label checkbox {
  transform: scale(0.78);
  margin-right: 2px;
}

.agreement-text {
  display: inline;
}

.agreement-link {
  display: inline;
  color: #07c160;
}

.auth-tip {
  text-align: center;
  font-size: 12px;
  color: #bbb;
  margin-top: 12px;
}
