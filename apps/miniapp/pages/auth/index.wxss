.auth-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #07c160 0%, #06ad56 40%, #f5f5f5 40%);
}

.auth-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 0 50px;
}

.auth-logo {
  width: 80px;
  height: 80px;
  border-radius: 16px;
  background-color: #fff;
  margin-bottom: 16px;
}

.auth-title {
  font-size: 22px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8px;
}

.auth-desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.85);
}

.auth-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 20px 60px;
}

.auth-agreement {
  text-align: center;
  font-size: 12px;
  color: #999;
  margin-top: 10px;
}

.agreement-text {
  display: inline;
}

.agreement-link {
  display: inline;
  color: #07c160;
}
