{
  "name": "housekeeping-staff-entry",
  "version": "0.1.0",
  "private": true,
  "description": "家政服务人员入驻独立小程序阶段一 MVP",
  "scripts": {
    "dev:server": "pnpm --filter @staff-entry/server dev",
    "dev:admin": "pnpm --filter @staff-entry/admin dev",
    "build:server": "pnpm --filter @staff-entry/server build",
    "build:admin": "pnpm --filter @staff-entry/admin build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css,scss,wxml,wxss}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css,scss,wxml,wxss}\"",
    "prisma:generate": "pnpm --filter @staff-entry/server prisma:generate",
    "prisma:migrate": "pnpm --filter @staff-entry/server prisma:migrate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
