# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/housekeeping_staff

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Local admin bootstrap
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change_me_before_running_seed

# WeChat Mini Program
WECHAT_APPID=your_appid
WECHAT_APPSECRET=your_appsecret

# File Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_BASE_PATH=./uploads

# OSS (only when STORAGE_PROVIDER=oss)
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=

# Encryption (for sensitive fields)
# 32-byte AES key encoded as base64. Generate a production key separately.
ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# File Preview
FILE_PREVIEW_URL_TTL_SECONDS=300
